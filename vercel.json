{
  "version": 2,
  "builds": [
    {
      "src": "bot.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/setwebhook",
      "dest": "bot.py"
    },
    {
      "src": "/(.*)",
      "dest": "bot.py"
    }
  ]
}
